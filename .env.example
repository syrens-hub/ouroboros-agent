# Ouroboros Agent — Environment Variables
# ========================================

# Safety
# ------
# Set to 1 to enable the interactive self-modification demo mode.
# Without this, all self-modification requests are denied by default.
OUROBOROS_DEMO_MODE=

# Web Server
# ----------
OUROBOROS_WEB_PORT=8080
# API token for protecting /api/* endpoints. Generate a strong random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEB_API_TOKEN=
# Comma-separated list of allowed origins for CORS (e.g. http://localhost:3000,https://mydomain.com)
WEB_ALLOWED_ORIGINS=

# LLM (Primary)
# -------------
# Provider: openai | anthropic | local
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your-api-key-here
# Optional: custom base URL (for local models or proxies)
# LLM_BASE_URL=http://localhost:11434/v1/chat/completions
# Optional: temperature and max tokens
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=4096

# LLM Fallback
# ------------
# Used by the resilience layer when the primary provider fails.
FALLBACK_LLM_PROVIDER=openai
FALLBACK_LLM_MODEL=gpt-4o-mini
FALLBACK_LLM_API_KEY=
# FALLBACK_LLM_BASE_URL=
# FALLBACK_LLM_TEMPERATURE=0.2
# FALLBACK_LLM_MAX_TOKENS=4096

# Logging
# -------
# Log levels: debug | info | warn | error
LOG_LEVEL=info
# Enable structured JSON logging (useful for log aggregation)
# LOG_FORMAT=json

# Database
# --------
# 生产部署推荐 PostgreSQL（多实例并发、高可用、行级锁）。
# 开发环境可使用 SQLite（零配置、单文件）。
#
# SQLite 配置
OUROBOROS_DB_DIR=.ouroboros
# DATABASE_PATH=./data/ouroboros.db
# SQLITE_WAL=true
#
# PostgreSQL 配置（生产推荐）
# ----------------------------
# Set to 1 to switch from SQLite to PostgreSQL.
# Requires: npm install pg
# See docs/database.md for full guide.
# USE_POSTGRES=1
# DATABASE_URL=postgresql://ouroboros:password@localhost:5432/ouroboros
# POSTGRES_POOL_SIZE=20
# POSTGRES_SSL=false
# SLOW_QUERY_THRESHOLD_MS=100

# Skills
# ------
# Directory for installed skills
OUROBOROS_SKILL_DIR=skills

# Redis (optional, enables distributed rate limiting and distributed locking)
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0
# REDIS_SENTINEL_MASTER=mymaster
# REDIS_SENTINEL_NODES=host1:26379,host2:26379
# REDIS_LOCK_TTL_MS=60000

# Sentry (optional error tracking)
# --------------------------------
# SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
# SENTRY_ENVIRONMENT=production

# Feishu Integration
# ------------------
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_WEBHOOK_PORT=3000
FEISHU_WEBHOOK_PATH=/feishu/webhook

# Semantic Cache
# --------------
# Enable semantic caching for LLM queries to reduce API costs.
# Cached by query embedding cosine similarity.
# SEMANTIC_CACHE_ENABLED=true
# SEMANTIC_CACHE_THRESHOLD=0.95
# SEMANTIC_CACHE_TTL_MS=604800000
# SEMANTIC_CACHE_MAX_ENTRIES=10000
# SEMANTIC_CACHE_DEFAULT_MODEL=default

# Cleanup / Retention
# -------------------
# Maximum number of DB backups (session-*.db) to retain in .ouroboros/backups.
# OUROBOROS_MAX_DB_BACKUPS=10
#
# Maximum number of evolution backups (evo-* dirs) to retain.
# OUROBOROS_MAX_EVOLUTION_BACKUPS=50
#
# Maximum number of shadow-git checkpoints to retain.
# OUROBOROS_MAX_CHECKPOINTS=30
#
# Number of days to retain backups/checkpoints before age-based pruning.
# OUROBOROS_RETENTION_DAYS=30
