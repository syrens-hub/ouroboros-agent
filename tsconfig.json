{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "@ouroboros/core/*": ["./core/*"],
      "@ouroboros/skills/*": ["./skills/*"],
      "@ouroboros/types": ["./types/index.ts"],
      "@ouroboros/extensions/*": ["./extensions/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist", "web", "skills/web-mcp/templates"]
}
